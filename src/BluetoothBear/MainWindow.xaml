<Window x:Class="BluetoothBear.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:BluetoothBear.Converters"
        xmlns:vm="clr-namespace:BluetoothBear.ViewModels"
        Title="BluetoothBear"
        Width="360" SizeToContent="Height" MaxHeight="520"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False"
        AllowsTransparency="True" Background="Transparent" Topmost="True"
        FontFamily="Segoe UI" TextOptions.TextFormattingMode="Display"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <conv:ConnectedBrushConverter x:Key="ConnectedBrush" />
        <conv:BatteryBrushConverter x:Key="BatteryBrush" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <conv:ErrorBrushConverter x:Key="ErrorBrush" />

        <!-- Pill button used inside cards and the header -->
        <Style x:Key="CardButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="7"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Hyperlink-like flat button -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#2563EB" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#1D4ED8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Thin rounded battery bar -->
        <Style x:Key="BatteryBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="6" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border CornerRadius="3" Background="#E5E7EB" />
                            <Border x:Name="PART_Track" />
                            <Border x:Name="PART_Indicator" CornerRadius="3"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Device card -->
        <DataTemplate DataType="{x:Type vm:DeviceViewModel}">
            <Border CornerRadius="10" Background="White" Margin="0,0,0,10" Padding="14">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Direction="270" Opacity="0.10" />
                </Border.Effect>
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Width="11" Height="11" VerticalAlignment="Center"
                                 Fill="{Binding IsConnected, Converter={StaticResource ConnectedBrush}}" />
                        <TextBlock Grid.Column="1" Margin="10,0,8,0" Text="{Binding Name}"
                                   FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="2" Text="{Binding BatteryText}" FontSize="13"
                                   FontWeight="SemiBold" Foreground="#374151" VerticalAlignment="Center"
                                   Visibility="{Binding HasBattery, Converter={StaticResource BoolToVis}}" />
                    </Grid>

                    <ProgressBar Style="{StaticResource BatteryBar}" Margin="21,10,0,0"
                                 Value="{Binding BatteryPercent, Mode=OneWay}"
                                 Foreground="{Binding BatteryPercent, Converter={StaticResource BatteryBrush}}"
                                 Visibility="{Binding HasBattery, Converter={StaticResource BoolToVis}}" />

                    <Grid Margin="0,12,0,0">
                        <TextBlock Text="{Binding StatusText}" Foreground="#6B7280" FontSize="12"
                                   VerticalAlignment="Center" />
                        <StackPanel HorizontalAlignment="Right">
                            <Button Content="Connect" Style="{StaticResource CardButton}"
                                    Background="#2563EB" Foreground="White"
                                    Command="{Binding ToggleCommand}"
                                    Visibility="{Binding IsConnected, Converter={StaticResource InverseBoolToVis}}" />
                            <Button Content="Disconnect" Style="{StaticResource CardButton}"
                                    Background="#EEF0F3" Foreground="#374151"
                                    Command="{Binding ToggleCommand}"
                                    Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Discovered (unpaired) device row -->
        <DataTemplate DataType="{x:Type vm:DiscoveredDeviceViewModel}">
            <Border CornerRadius="10" Background="White" Margin="0,0,0,8" Padding="12,10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Direction="270" Opacity="0.08" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding StatusText}" FontSize="11" Margin="0,2,0,0"
                                   Foreground="{Binding IsError, Converter={StaticResource ErrorBrush}}"
                                   Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Pair" Style="{StaticResource CardButton}"
                            Background="#2563EB" Foreground="White" VerticalAlignment="Center"
                            Command="{Binding PairCommand}" />
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <!-- Outer card: rounded, drop-shadowed; the 12px margin leaves room for the shadow. -->
    <Border Margin="12" CornerRadius="12" Background="#F1F2F4">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="2" Direction="270" Opacity="0.30" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="16,14,16,8">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="BluetoothBear" FontSize="16" FontWeight="Bold" Foreground="#111827" />
                    <TextBlock Text="{Binding StatusSummary}" FontSize="12" Foreground="#6B7280" Margin="0,2,0,0" />
                </StackPanel>
                <Button Content="⟳  Refresh" Style="{StaticResource CardButton}"
                        Background="#E5E7EB" Foreground="#374151"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Command="{Binding RefreshCommand}" />
            </Grid>

            <!-- Pair a new device (hidden while in the discovery view) -->
            <Button Grid.Row="1" Content="＋  Add a device" Style="{StaticResource CardButton}"
                    Background="#E8EFFE" Foreground="#2563EB"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Margin="16,0,16,10" Command="{Binding BeginAddDeviceCommand}"
                    Visibility="{Binding ShowDeviceList, Converter={StaticResource BoolToVis}}" />

            <!-- Device list (paired) -->
            <Grid Grid.Row="2" Visibility="{Binding ShowDeviceList, Converter={StaticResource BoolToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="380" Padding="16,2,16,2">
                    <ItemsControl ItemsSource="{Binding Devices}" />
                </ScrollViewer>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,28"
                            Visibility="{Binding HasNoDevices, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="No paired devices found" FontSize="13" Foreground="#6B7280"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Use ＋ Add a device to pair one." FontSize="11"
                               Foreground="#9CA3AF" Margin="0,4,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- Discovery view (in-app pairing) -->
            <DockPanel Grid.Row="2" Visibility="{Binding IsDiscovering, Converter={StaticResource BoolToVis}}">
                <Grid DockPanel.Dock="Top" Margin="16,0,16,6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="←" Style="{StaticResource CardButton}"
                                Background="#E5E7EB" Foreground="#374151" Padding="11,4"
                                Command="{Binding CloseDiscoveryCommand}" />
                        <TextBlock Text="Add a device" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="10,0,0,0" />
                    </StackPanel>
                </Grid>
                <StackPanel DockPanel.Dock="Top" Margin="16,0,16,8">
                    <TextBlock Text="Searching for nearby devices…" FontSize="11" Foreground="#6B7280" />
                    <ProgressBar IsIndeterminate="True" Height="3" Margin="0,6,0,0"
                                 Background="#E5E7EB" Foreground="#2563EB" BorderThickness="0" />
                </StackPanel>
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300" Padding="16,2,16,4">
                        <ItemsControl ItemsSource="{Binding Discovered}" />
                    </ScrollViewer>
                    <TextBlock Text="Put your device in pairing mode so it shows up here."
                               Margin="20,12" FontSize="12" Foreground="#9CA3AF" TextWrapping="Wrap"
                               HorizontalAlignment="Center" VerticalAlignment="Top" TextAlignment="Center"
                               Visibility="{Binding HasNoDiscovered, Converter={StaticResource BoolToVis}}" />
                </Grid>
            </DockPanel>

            <!-- Footer -->
            <Border Grid.Row="3" BorderThickness="0,1,0,0" BorderBrush="#E3E5E9" Padding="16,9,16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <CheckBox Grid.Column="0" Content="Start with Windows" VerticalAlignment="Center"
                              FontSize="12" Foreground="#374151" Cursor="Hand"
                              IsChecked="{Binding StartWithWindows, Mode=TwoWay}" />
                    <Button Grid.Column="1" Content="Open Bluetooth settings" Style="{StaticResource LinkButton}"
                            VerticalAlignment="Center" Click="OpenSettings_Click" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
